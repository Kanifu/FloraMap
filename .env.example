# ── Development (direct Gemini API) ────────────────────────────────────────
# Get a free key at https://aistudio.google.com
EXPO_PUBLIC_GEMINI_API_KEY=your_key_here

# ── Production (Cloudflare Worker proxy) ───────────────────────────────────
# Set these instead of GEMINI_API_KEY for production builds.
# See cloudflare-worker/README.md for setup.
#
# EXPO_PUBLIC_API_PROXY_URL=https://floramap-proxy.<your-subdomain>.workers.dev
# EXPO_PUBLIC_API_TOKEN=your_random_shared_secret

{
  "expo": {
    "name": "FloraMap",
    "slug": "floramap",
    "version": "1.3.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "extra": {
      "eas": {
        "projectId": "30354417-a06c-409c-aa8b-2f1bcdae0928"
      }
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "FloraMap uses your camera to scan your garden and identify plants."
        }
      ],
      "expo-notifications"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.floramap.app"
    },
    "android": {
      "package": "com.floramap.app",
      "versionCode": 1,
      "permissions": ["android.permission.CAMERA"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1b4332"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}

{
  "expo": {
    "name": "FloraMap",
    "slug": "floramap",
    "version": "1.7.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "extra": {
      "buildLabel": "7.3",
      "buildDate": "29 mei 2026",
      "eas": {
        "projectId": "30354417-a06c-409c-aa8b-2f1bcdae0928"
      }
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "FloraMap uses your camera to scan your garden and identify plants."
        }
      ],
      "expo-notifications",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "FloraMap uses your location to show accurate local weather for your garden."
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.floramap.app"
    },
    "android": {
      "package": "com.floramap.app",
      "versionCode": 31,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1b4332"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}

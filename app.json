{
  "expo": {
    "name": "FloraMap",
    "slug": "floramap",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "FloraMap uses your camera to scan your garden and identify plants."
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.floramap.app"
    },
    "android": {
      "package": "com.floramap.app",
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "bundler": "metro"
    }
  }
}
